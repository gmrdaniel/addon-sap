# Plantilla de variables de entorno para el backend local (Paso 7).
# Copiar a deploy/env/.env y completar. NO subir .env al repositorio.

# Base de datos (placeholder PostgreSQL; confirmar motor en Fase 0)
DB_NAME=ln_billing
DB_USER=ln_app
DB_PASSWORD=cambia_esta_clave

# Proveedor de IA de visión (Stub | OpenAI | AzureOpenAI) — confirmar en Fase 0
VISION_PROVIDER=Stub
# La API key vive SOLO en el backend, nunca en las estaciones del add-on
VISION_API_KEY=
